{
  "name": "ubeye",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "ios:generate": "cd apps/ios && xcodegen generate",
    "ios:open": "open apps/ios/UBEYE.xcodeproj",
    "ios:build:debug": "cd apps/ios && xcodebuild -project UBEYE.xcodeproj -scheme UBEYE -sdk iphonesimulator -configuration Debug CODE_SIGNING_ALLOWED=NO build",
    "ios:build:release": "cd apps/ios && xcodebuild -project UBEYE.xcodeproj -scheme UBEYE -destination 'generic/platform=iOS' -configuration Release CODE_SIGNING_ALLOWED=NO build",
    "ios:archive:unsigned": "cd apps/ios && xcodebuild -project UBEYE.xcodeproj -scheme UBEYE -destination 'generic/platform=iOS' -configuration Release CODE_SIGNING_ALLOWED=NO archive -archivePath /tmp/UBEYE.xcarchive",
    "mobile:start": "npm run ios:open",
    "mobile:ios": "npm run ios:build:debug",
    "db:check": "drizzle-kit check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.1.0",
    "@ubeye/shared": "file:packages/shared",
    "@vercel/blob": "^2.3.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.8.0",
    "next": "16.2.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "sharp": "^0.34.5",
    "stripe": "^22.1.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "shadcn": "^4.3.0",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  },
  "overrides": {
    "postcss": "8.5.10"
  }
}
