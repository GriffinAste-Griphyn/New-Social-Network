{
  "expo": {
    "name": "UBEYE",
    "slug": "ubeye",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ubeye",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.griffinaste.ubeye"
    },
    "android": {
      "package": "com.griffinaste.ubeye",
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-video",
      "expo-notifications",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow UBEYE to access your camera so you can capture stories."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
